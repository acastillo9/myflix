# MyFlix Configuration
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# =============================================================================
# User/Group IDs — run `id $USER` on your Linux server to find these
# =============================================================================
PUID=1000
PGID=1000

# =============================================================================
# Timezone — https://en.wikipedia.org/wiki/List_of_tz_database_time_zones
# =============================================================================
TZ=America/New_York

# =============================================================================
# Storage paths on the Linux server
# =============================================================================
# Root of your media storage (where downloads + media libraries live)
# Must be a single ext4 filesystem for hardlinks to work
DATA_ROOT=/media/storage

# Where container configs/databases are stored (survives container rebuilds)
APPDATA_ROOT=/media/storage/appdata

# =============================================================================
# Cleanup mode: "ephemeral" or "persistent"
#   ephemeral — auto-delete media older than 48h (Phase 0, limited storage)
#   persistent — only delete downloads with hardlink count >= 2, keep library
# =============================================================================
CLEANUP_MODE=ephemeral
CLEANUP_MAX_AGE_HOURS=48

# =============================================================================
# Service ports — change if you have conflicts on your server
# =============================================================================
JELLYFIN_PORT=8096
SEERR_PORT=5055
RADARR_PORT=7878
SONARR_PORT=8989
LIDARR_PORT=8686
READARR_PORT=8787
KAVITA_PORT=5000
PROWLARR_PORT=9696
BAZARR_PORT=6767
QBIT_WEBUI_PORT=8085
QBIT_TORRENT_PORT=6881
FLARESOLVERR_PORT=8191

# =============================================================================
# Watchtower — auto-update interval in seconds (86400 = daily)
# =============================================================================
WATCHTOWER_POLL_INTERVAL=86400

# =============================================================================
# Backup Configuration
#   RETENTION_DAYS: How many days of backups to keep (default: 30)
# =============================================================================
BACKUP_RETENTION_DAYS=30

# =============================================================================
# Health Check Configuration
#   ALERT_EMAIL: Email address for service failure alerts (optional)
# =============================================================================
HEALTHCHECK_ALERT_EMAIL=

# =============================================================================
# Reverse Proxy Configuration (optional HTTPS via Traefik)
#   Start with: docker compose --profile traefik up -d
#   Requires ports 80 and 443 to be accessible on your server.
# =============================================================================
DOMAIN=yourdomain.com
TRAEFIK_ACME_EMAIL=your@email.com
